{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "RLModel": {
      "title": "RL Model",
      "description": "Definition of a reinforcement learning model/environment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["CartPole", "Pendulum", "LunarLander", "BipedalWalker"] },
        "description": { "type": "string" },
        "thumbnail": { "type": "string" }
      },
      "required": ["id", "name", "type"]
    },
    "TrainingSession": {
      "title": "Training Session",
      "description": "A specific instance of a training run.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "modelId": { "type": "string" },
        "status": { "type": "string", "enum": ["idle", "training", "completed", "failed"] },
        "config": { "type": "object" },
        "metrics": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "modelId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/models/{modelId}": {
      "schema": "RLModel",
      "description": "Available RL models."
    },
    "/sessions/{sessionId}": {
      "schema": "TrainingSession",
      "description": "Training session records."
    }
  }
}
